# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL individual credentials (used by the postgres container)
POSTGRES_DB=autoscreen
POSTGRES_USER=autoscreen
POSTGRES_PASSWORD=CHANGE_ME

# Full connection string used by the API and worker
# Host is the service name "postgres" (internal Docker network)
DATABASE_URL=postgresql://autoscreen:CHANGE_ME@postgres:5432/autoscreen

# ── Redis ─────────────────────────────────────────────────────────────────────
# Host is the service name "redis" (internal Docker network)
REDIS_URL=redis://redis:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong random value:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME

# ── OpenAI ────────────────────────────────────────────────────────────────────
DEFAULT_OPENAI_API_KEY=sk-...

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
